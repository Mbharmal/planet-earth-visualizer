{
  "name": "planet-earth-visualizer",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "shared",
    "generator",
    "app"
  ],
  "scripts": {
    "dev": "npm run dev -w app",
    "build": "npm run build -w app",
    "preview": "npm run preview -w app",
    "generate": "npm run generate -w generator --",
    "typecheck": "tsc --noEmit -p shared && tsc --noEmit -p generator && tsc --noEmit -p app",
    "test": "npm run test -w shared"
  },
  "devDependencies": {
    "puppeteer-core": "^25.3.0"
  }
}
